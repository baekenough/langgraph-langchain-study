# ============================================================
# LangChain + LangGraph 학습 환경 — API 키 설정 예시
#
# 사용법:
#   cp .env.example .env
#   .env 파일을 열어 실제 API 키 값을 입력하세요.
#
# 주의: .env 파일은 절대 Git에 커밋하지 마세요!
# ============================================================

# ------------------------------------------------------------
# OpenRouter — 필수 (채팅 모델용)
# 단일 API 키로 OpenAI/Anthropic/Google/Meta 등 여러 모델에 접근
# OpenAI 호환 API이므로 ChatOpenAI + base_url로 사용
# 발급: https://openrouter.ai/ → Keys
# ------------------------------------------------------------
OPENROUTER_API_KEY=

# ------------------------------------------------------------
# OpenAI — RAG 파트에서 필요 (임베딩 전용)
# OpenRouter는 임베딩 API를 제공하지 않으므로 별도로 필요
# 채팅 모델은 OpenRouter를 사용하므로 임베딩 용도로만 사용
# 발급: https://platform.openai.com/api-keys
# ------------------------------------------------------------
OPENAI_API_KEY=

# ------------------------------------------------------------
# LangSmith — 강력 권장 (트레이싱, 디버깅, 평가)
# 발급: https://smith.langchain.com/ → Settings → API Keys
# ------------------------------------------------------------
LANGSMITH_API_KEY=

# LangSmith 트레이싱 활성화 (true/false)
LANGSMITH_TRACING=true

# LangSmith 프로젝트 이름 (구분용)
LANGSMITH_PROJECT=langchain-langgraph-study

# ------------------------------------------------------------
# Tavily — 선택 (웹 검색 도구용)
# 발급: https://tavily.com/ → API
# ------------------------------------------------------------
TAVILY_API_KEY=
